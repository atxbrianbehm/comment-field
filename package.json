{
  "name": "comment-field",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "typecheck:engine": "tsc -p packages/comment-field-engine/tsconfig.json --pretty false",
    "typecheck:runtime": "tsc -p packages/comment-field-webgpu-runtime/tsconfig.json --pretty false",
    "verify:architecture": "node scripts/verify-architecture.mjs",
    "verify": "npm run verify:architecture && npm run typecheck:engine && npm run typecheck:runtime && npm run test:run && npm run build",
    "test": "vitest",
    "test:run": "vitest run",
    "preview": "vite preview"
  },
  "dependencies": {
    "fflate": "^0.8.3",
    "idb": "^8.0.3",
    "lucide-react": "^1.24.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.185.1",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "jsdom": "^29.1.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
